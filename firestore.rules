rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "samuelemma466@gmail.com" && request.auth.token.email_verified == true));
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    
    function isValidUser(data) {
      return hasOnlyAllowedFields(['uid', 'email', 'balance', 'role', 'createdAt']) &&
        data.uid is string && data.uid.size() > 0 && data.uid.size() < 50 &&
        data.email is string && data.email.size() > 0 && data.email.size() < 100 &&
        data.balance is number && data.balance >= 0 &&
        data.role in ['user', 'admin'] &&
        data.createdAt is string && data.createdAt.size() > 0 && data.createdAt.size() < 50;
    }
    
    function isValidTransaction(data) {
      return hasOnlyAllowedFields(['id', 'userId', 'type', 'asset', 'amount', 'rate', 'total', 'status', 'proofUrl', 'createdAt']) &&
        data.id is string && data.id.size() > 0 && data.id.size() < 50 &&
        data.userId is string && data.userId.size() > 0 && data.userId.size() < 50 &&
        data.type in ['crypto', 'fiat', 'giftcard'] &&
        data.asset is string && data.asset.size() > 0 && data.asset.size() < 50 &&
        data.amount is number && data.amount > 0 &&
        data.rate is number && data.rate > 0 &&
        data.total is number && data.total > 0 &&
        data.status in ['pending', 'approved', 'rejected'] &&
        (!('proofUrl' in data) || (data.proofUrl is string && data.proofUrl.size() < 500)) &&
        data.createdAt is string && data.createdAt.size() > 0 && data.createdAt.size() < 50;
    }
    
    function isValidRate(data) {
      return hasOnlyAllowedFields(['asset', 'rate', 'updatedAt']) &&
        data.asset is string && data.asset.size() > 0 && data.asset.size() < 50 &&
        data.rate is number && data.rate > 0 &&
        data.updatedAt is string && data.updatedAt.size() > 0 && data.updatedAt.size() < 50;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && 
                    isOwner(userId) && request.resource.data.uid == userId &&
                    ((request.resource.data.role == 'user') || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && 
                    request.resource.data.uid == resource.data.uid &&
                    ((isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin());
      allow delete: if isAdmin();
    }
    
    match /transactions/{transactionId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuthenticated() && isValidTransaction(request.resource.data) && 
                    isOwner(request.resource.data.userId) && 
                    request.resource.data.status == 'pending';
      allow update: if isAuthenticated() && isValidTransaction(request.resource.data) && 
                    request.resource.data.userId == resource.data.userId &&
                    ((isOwner(resource.data.userId) && request.resource.data.status == resource.data.status) || isAdmin());
      allow delete: if isAdmin();
    }
    
    match /rates/{rateId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isValidRate(request.resource.data);
      allow update: if isAdmin() && isValidRate(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
