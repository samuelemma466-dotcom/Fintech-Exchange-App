{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "balance": { "type": "number" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "balance", "role", "createdAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A financial transaction (crypto, fiat, giftcard)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["crypto", "fiat", "giftcard"] },
        "asset": { "type": "string" },
        "amount": { "type": "number" },
        "rate": { "type": "number" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "proofUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "type", "asset", "amount", "rate", "total", "status", "createdAt"]
    },
    "Rate": {
      "title": "Rate",
      "description": "Exchange rates",
      "type": "object",
      "properties": {
        "asset": { "type": "string" },
        "rate": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["asset", "rate", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/transactions/{transactionId}": {
      "schema": { "$ref": "#/entities/Transaction" },
      "description": "User transactions"
    },
    "/rates/{rateId}": {
      "schema": { "$ref": "#/entities/Rate" },
      "description": "Exchange rates for different assets"
    }
  }
}
